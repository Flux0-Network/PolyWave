# Copy to .env.local for local dev. Not needed if the bot runs on the same
# machine and writes data/state.json next to this repo (the default) -- the
# dashboard falls back to reading that file when these are unset.

# Set these (matching the bot's KV_REST_API_URL / KV_REST_API_TOKEN in its
# .env) to read state from the same Upstash-compatible KV store the bot
# pushes to. Required when deploying this app to Vercel, since Vercel
# functions can't read the bot's local filesystem.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Only used when the KV vars above are not set. Defaults to ../data/state.json.
STATE_FILE_PATH=
