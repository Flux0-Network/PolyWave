# Copy to .env.local for local dev. Not needed if the bot runs on the same
# machine and writes data/state.json next to this repo (the default) -- the
# dashboard falls back to reading that file when these are unset.

# Set these (matching the bot's SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY in
# its .env) to read state from the same Supabase table the bot pushes to.
# Required when deploying this app to Vercel, since Vercel functions can't
# read the bot's local filesystem. Use the service_role key, not anon.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# How many seconds old a snapshot may be before it's treated as stale.
# Should match the bot's STATE_TTL_SECONDS.
STATE_TTL_SECONDS=120

# Only used when the Supabase vars above are not set. Defaults to
# ../data/state.json.
STATE_FILE_PATH=
