# Copy to .env and fill in before running with DRY_RUN=false.
# Never commit your real .env file.

# --- Safety ---
# true = simulate everything, no orders are ever sent to Polymarket.
# Keep this "true" until you have tested the bot thoroughly.
DRY_RUN=true

# --- Polymarket wallet / CLOB credentials (only needed when DRY_RUN=false) ---
# Private key of the Polygon wallet that holds your USDC and will sign orders.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
# Optional: if omitted, API creds are derived from the private key on startup.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Market discovery ---
GAMMA_API_URL=https://gamma-api.polymarket.com

# --- Price feed ---
BINANCE_API_URL=https://api.binance.com
BTC_SYMBOL=BTCUSDT

# --- Strategy ---
# Momentum lookback window used to decide Up vs Down.
MOMENTUM_LOOKBACK_SECONDS=60
# Minimum move (in basis points, 1bps = 0.01%) required to take a position.
# Anything smaller than this is treated as noise and skipped.
MOMENTUM_THRESHOLD_BPS=15

# --- Timing (relative to each 5-minute market window) ---
# Don't enter within the first N seconds after a market opens (let price settle).
ENTRY_BUFFER_SECONDS=30
# Don't enter within the last N seconds before a market closes (avoid fill/slippage risk).
EXIT_BUFFER_SECONDS=20
# How often the bot polls for market state / price, in seconds.
POLL_INTERVAL_SECONDS=5
# How often to log a trade-stats summary (trades, win rate, PnL), in seconds.
STATS_LOG_INTERVAL_SECONDS=900

# --- Risk management ---
# USDC amount risked per trade.
TRADE_SIZE_USDC=5
# Bot stops opening new trades once realized losses for the day reach this amount.
MAX_DAILY_LOSS_USDC=50

# --- Dashboard ---
# Local snapshot file the dashboard reads when run on the same machine.
STATE_FILE_PATH=data/state.json
# Optional: also push the state snapshot to an Upstash-compatible REST KV
# store, so a dashboard deployed on Vercel (which can't read this machine's
# disk) can see it. Leave blank to only write the local file. See
# dashboard/README.md for setup. Use the exact same values as the
# KV_REST_API_URL / KV_REST_API_TOKEN env vars you set on the Vercel project.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# How long a pushed snapshot stays valid in the KV store, in seconds. If the
# bot stops running, the dashboard falls back to "no data" after this long
# instead of showing stale state forever.
STATE_TTL_SECONDS=120
